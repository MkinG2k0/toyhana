generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============ AUTH (OTP) ============

model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([phone])
  @@map("otp_codes")
}

// ============ USERS ============

model User {
  id             String    @id @default(cuid())
  phone          String?   @unique
  email          String?   @unique
  name           String
  role           UserRole  @default(CLIENT)
  avatar         String?
  telegramChatId String?
  whatsappPhone  String?

  venues                  Venue[]
  bookings                Booking[]
  reviews                 Review[]
  venuePlacementRequests  VenuePlacementRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@map("users")
}

enum UserRole {
  CLIENT
  OWNER
  ADMIN
}

// ============ VENUES ============

model Venue {
  id          String @id @default(cuid())
  slug        String @unique
  name        String
  description String @db.Text

  address   String
  city      String  @default("Махачкала")
  district  String?
  latitude  Float?
  longitude Float?

  capacityMin    Int
  capacityMax    Int
  pricePerPerson Int
  rentalPrice    Int?

  hasHalalKitchen  Boolean @default(true)
  allowOwnCook     Boolean @default(false)
  hasPrayerRoom    Boolean @default(false)
  hasSeparateHalls Boolean @default(false)
  allowOwnFruits   Boolean @default(true)

  hasStage       Boolean @default(false)
  hasProjector   Boolean @default(false)
  hasParking     Boolean @default(false)
  hasSoundSystem Boolean @default(false)
  hasWelcomeZone Boolean @default(false)
  hasOutdoorArea Boolean @default(false)

  cuisineTypes String[]

  photos       VenuePhoto[]
  blockedDates BlockedDate[]
  bookings     Booking[]
  reviews      Review[]

  isActive     Boolean   @default(true)
  isVerified   Boolean   @default(false)
  isApproved   Boolean   @default(false)
  isPremium    Boolean   @default(false)
  premiumUntil DateTime?

  owner   User   @relation(fields: [ownerId], references: [id])
  ownerId String

  averageRating Float @default(0)
  reviewCount   Int   @default(0)
  viewCount     Int   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([city, isActive, isApproved])
  @@index([isApproved, isActive])
  @@index([pricePerPerson])
  @@index([capacityMax])
  @@index([averageRating])
  @@index([isPremium, averageRating])
  @@map("venues")
}

model VenuePhoto {
  id     String  @id @default(cuid())
  url    String
  key    String
  order  Int     @default(0)
  isMain Boolean @default(false)

  venue   Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)
  venueId String

  @@map("venue_photos")
}

model BlockedDate {
  id     String   @id @default(cuid())
  date   DateTime @db.Date
  reason String?

  venue   Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)
  venueId String

  @@unique([venueId, date])
  @@map("blocked_dates")
}

// ============ BOOKINGS ============

model Booking {
  id String @id @default(cuid())

  eventDate    DateTime      @db.Date
  eventType    EventType     @default(WEDDING)
  guestCount   Int
  contactName  String
  contactPhone String
  message      String?       @db.Text

  status BookingStatus @default(PENDING)

  totalPrice    Int?
  prepaidAmount Int?
  paymentId     String?
  paidAt        DateTime?

  venue    Venue  @relation(fields: [venueId], references: [id])
  venueId  String
  client   User   @relation(fields: [clientId], references: [id])
  clientId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([venueId, eventDate])
  @@index([clientId])
  @@index([status])
  @@map("bookings")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  PREPAID
  COMPLETED
  CANCELLED
  REJECTED
}

enum EventType {
  WEDDING
  ENGAGEMENT
  BIRTHDAY
  CORPORATE
  FUNERAL
  OTHER
}

// ============ VENUE PLACEMENT REQUESTS ============

model VenuePlacementRequest {
  id           String                      @id @default(cuid())
  description  String                      @db.Text
  status       VenuePlacementRequestStatus @default(PENDING)
  adminComment String?                     @db.Text

  user   User   @relation(fields: [userId], references: [id])
  userId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([userId])
  @@map("venue_placement_requests")
}

enum VenuePlacementRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// ============ REVIEWS ============

model Review {
  id             String  @id @default(cuid())
  rating         Int
  text           String  @db.Text
  foodRating     Int?
  serviceRating  Int?
  ambienceRating Int?
  isModerated    Boolean @default(false)

  venue    Venue  @relation(fields: [venueId], references: [id])
  venueId  String
  author   User   @relation(fields: [authorId], references: [id])
  authorId String

  createdAt DateTime @default(now())

  @@unique([venueId, authorId])
  @@map("reviews")
}
